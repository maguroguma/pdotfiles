#!/usr/bin/env bash
#

# Thanks to: https://zenn.dev/layerx/articles/8c29b0367238b8#tmux-session-%E3%81%AF-ghq-%E3%81%A7%E7%AE%A1%E7%90%86%E3%81%99%E3%82%8B%E3%83%87%E3%82%A3%E3%83%AC%E3%82%AF%E3%83%88%E3%83%AA%E3%81%AB%E5%AF%BE%E5%BF%9C%E3%81%95%E3%81%9B%E3%82%8B

set -euo pipefail

changeSession() {
  local change
  [[ -n "${TMUX:-""}" ]] && change="switch-client" || change="attach-session"
  tmux $change -t "$1"
}

createSessionIfNeeded() {
  local name=$1
  [[ -n "$2" ]] && dir=$2 || dir=$(pwd)
  tmux list-sessions -F "#{session_name}" |
    grep -q -E "^${name}$" ||
    tmux new-session -c "${dir}" -s "${name}" \; \
      split-window -c "${dir}" -h \; \
      select-layout main-vertical \; \
      select-pane -L \; \
      detach-client
}

selectRepo() {
  local selected
  selected=$(ghq list | fzf --prompt='make session> ') || exit 0
  echo "$(ghq root)/${selected}"
}

# 既存 tmux セッション一覧から DD_ フォーマットの最大番号を取得し、
# 次の prefix（ゼロ埋め2桁）を返す。
# セッションが存在しない・DD_ 形式がない場合は "01" を返す。
getNextPrefix() {
  local max_num=0
  local found=0

  while IFS= read -r session_name; do
    if [[ "$session_name" =~ ^([0-9]{2})_ ]]; then
      found=1
      local num_val=$((10#${BASH_REMATCH[1]}))
      if [ "$num_val" -gt "$max_num" ]; then
        max_num=$num_val
      fi
    fi
  done < <(tmux list-sessions -F "#{session_name}" 2>/dev/null)

  if [ "$found" -eq 0 ]; then
    echo "01"
  else
    printf "%02d" $((max_num + 1))
  fi
}

main() {
  if [ $# -eq 1 ]; then
    createSessionIfNeeded $1
    changeSession $1
    exit
  fi

  local repo="$(selectRepo)"
  local prefix="$(getNextPrefix)"
  local session="${prefix}_$(echo "$repo" | awk -F/ '{ print $(NF-1)"/"$NF }')"

  createSessionIfNeeded $session $repo
  changeSession $session
}

main "$@"
