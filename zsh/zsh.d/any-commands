brew list
brew leaves ### 自分で入れたものだけ確認する
brew deps --tree #{package} ### 指定したパッケージの依存ツリーを確認する
brew uses --installed #{package} ### 指定したパッケージに依存しているものを確認する
brew tap ### homebrew-core 以外のものを確認する
brew info #{package}
brew outdated
brew doctor

tmux send-keys -t #{pane_id} #{keys} Enter

ls -l | grep '^l' ### カレントディレクトリのシンボリックリンクのみを表示する

open "obsidian://open?path=$(pwd)" ### カレントディレクトリ（またはfzfで選んだフォルダ）をObsidianで開く
